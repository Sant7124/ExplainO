# ExplainO Security & Environment Ignores

# --------------------------------------------------------------------------
# CRITICAL: Security & Confidentiality
# --------------------------------------------------------------------------
.env
backend/.env
frontend/.env
*.pem
*.key
*.cert
secrets.json

# --------------------------------------------------------------------------
# Databases (Contains user intelligence data)
# --------------------------------------------------------------------------
backend/data/*.db
backend/chroma_db/
chroma_db/
data/
*.sqlite3

# --------------------------------------------------------------------------
# User Data (Uploaded documents)
# --------------------------------------------------------------------------
backend/uploads/
uploads/

# --------------------------------------------------------------------------
# Logs
# --------------------------------------------------------------------------
*.log
backend/*.log
server_stdout.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------------------------------------------------------
# Python (Backend)
# --------------------------------------------------------------------------
__pycache__/
backend/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --------------------------------------------------------------------------
# Node.js (Frontend)
# --------------------------------------------------------------------------
frontend/node_modules/
node_modules/
frontend/dist/
frontend/dist-ssr/
.npm
.eslintcache

# --------------------------------------------------------------------------
# IDEs & System
# --------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
